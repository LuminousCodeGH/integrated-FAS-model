               RowBox[{
                RowBox[{"\"\<BestGeneration\>\"", "->", "genCounter"}], ",", 
                RowBox[{"\"\<BestBeta\>\"", "->", "bet"}], ",", 
                RowBox[{"\"\<BestScore\>\"", "->", 
                 RowBox[{"-", "bestScore"}]}]}], "|>"}]}], "]"}]}]}], ")"}]}],
