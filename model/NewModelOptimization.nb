Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"malCoAInputs", "=", 
  RowBox[{"{", 
   RowBox[{"100", ",", "125", ",", "150"}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ConcPL", "=", 
    RowBox[{
     FractionBox[
      RowBox[{"22", "*", " ", 
       SuperscriptBox["10", "6"]}], 
      RowBox[{"Vcell", " ", "nA"}]], "*", 
     SuperscriptBox["10", "6"]}]}], ";"}], 
  RowBox[{"(*", " ", "micromolar", " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DilutionPL", "=", 
   FractionBox[
    RowBox[{"experimentalGrowth", " ", "ConcPL"}], 
    SuperscriptBox["60", "2"]]}], 
  RowBox[{"(*", " ", 
   RowBox[{"micromolar", " ", "/", " ", "s"}], "*)"}], "\[IndentingNewLine]", 
  
  RowBox[{"(*", 
   RowBox[{"Set", " ", "up", " ", "the", " ", "parallelization"}], "*)"}]}], "\n", 
 RowBox[{"LaunchKernels", "[", 
  RowBox[{"Length", "[", "malCoAInputs", "]"}], "]"}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{"ParallelEvaluate", "[", 
    RowBox[{"Off", "[", 
     RowBox[{"FindRoot", "::", "lstol"}], "]"}], "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"EvaluateSteadyStateFluxes", "[", 
    RowBox[{
     RowBox[{"malCoA_", "?", "NumericQ"}], ",", 
     RowBox[{"PlsBbeta_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ODEsFinalLocal", ",", "initsFinalLocal", ",", "tsol", ",", "tsolSS", ",",
        "JsPL", ",", "JsLP", ",", "steadyStateEqs", ",", "varsSS", ",", 
       "rhsReplaceMap", ",", "initialGuessValues", ",", "guessPairs", ",", 
       RowBox[{"timeSS", "=", "99000"}]}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{"Setup", " ", "initial", " ", "conditions"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"initsFinalLocal", "=", 
       RowBox[{"inits", "/.", " ", "kinParamsIO"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"initsFinalLocal", "=", 
       RowBox[{"initsFinalLocal", "/.", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"y4", "[", "0", "]"}], "==", "_"}], ":>", 
          RowBox[{
           RowBox[{"y4", "[", "0", "]"}], "==", "ACPconc"}]}], ")"}]}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Setup", " ", "ODEs", " ", "and", " ", "apply", " ", "global", " ", 
        RowBox[{"parameter", "/", "concentration"}], " ", "blocks"}], "*)"}], 
      
      RowBox[{"ODEsFinalLocal", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"ODEs", "/.", " ", "kinParamsFAS"}], "/.", " ", 
             "kinParamsLiPh"}], "/.", " ", "kinParamsIO"}], "/.", " ", 
           "enzymeConcsFAS"}], "/.", " ", "enzymeConcsLPS"}], "/.", " ", 
         "enzymeConcsPLS"}], "/.", " ", 
        RowBox[{"(", 
         RowBox[{"y2ref", "->", "0"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Inject", " ", "the", " ", "current", " ", "Mal"}], "-", 
        RowBox[{"CoA", " ", "condition"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"ODEsFinalLocal", "=", 
       RowBox[{"ODEsFinalLocal", "/.", " ", 
        RowBox[{"(", 
         RowBox[{"y8ref", "->", "malCoA"}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Inject", " ", "the", " ", "parameters", " ", "being", " ", "tuned", " ",
         "by", " ", "NMinimize"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"ODEsFinalLocal", "=", 
       RowBox[{
        RowBox[{"ODEsFinalLocal", "/.", " ", "optParams"}], "/.", 
        RowBox[{"{", 
         RowBox[{"beta", "->", "PlsBbeta"}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Run", " ", "NDSolve", " ", "to", " ", "get", " ", "close", " ", "to", 
        " ", "steady", " ", "state", " ", 
        RowBox[{"(", 
         RowBox[{"Provides", " ", "initial", " ", "guess"}], ")"}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"tsol", "=", 
       RowBox[{"NDSolve", "[", 
        RowBox[{
         RowBox[{"Join", "[", 
          RowBox[{"ODEsFinalLocal", ",", "initsFinalLocal"}], "]"}], ",", 
         "vars", ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "0", ",", "timeSS"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Convert", " ", "ODEs", " ", "to", " ", "algebraic", " ", 
        "equations"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"steadyStateEqs", "=", 
       RowBox[{"ODEsFinalLocal", "/.", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Equal", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Derivative", "[", "1", "]"}], "[", "_", "]"}], "[", 
              "t", "]"}], ",", "rhs_"}], "]"}], ":>", "rhs"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"(", "var_", ")"}], "[", "t", "]"}], ":>", "var"}]}], 
         "}"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"varsSS", "=", 
       RowBox[{"vars", "/.", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"(", "var_", ")"}], "[", "t", "]"}], ":>", "var"}]}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"rhsReplaceMap", "=", 
       RowBox[{"Thread", "[", 
        RowBox[{"vars", "->", "varsSS"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"steadyStateEqs", "=", 
       RowBox[{"steadyStateEqs", "/.", " ", "rhsReplaceMap"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Get", " ", "initial", " ", "guess", " ", "from", " ", "NDSolve", " ", 
        "solution"}], "*)"}], 
      RowBox[{"initialGuessValues", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"vars", "/.", " ", "tsol"}], "/.", " ", 
          RowBox[{"t", "->", "timeSS"}]}], ")"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"guessPairs", "=", 
       RowBox[{"Thread", "[", 
        RowBox[{"{", 
         RowBox[{"varsSS", ",", "initialGuessValues"}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Solve", " ", "for", " ", "exact", " ", "steady", " ", "state"}], 
       "*)"}], 
      RowBox[{"tsolSS", "=", 
       RowBox[{"FindRoot", "[", 
        RowBox[{
         RowBox[{"Thread", "[", 
          RowBox[{"steadyStateEqs", "==", "0"}], "]"}], ",", "guessPairs", ",", 
         RowBox[{"MaxIterations", "->", "5000"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Calculate", " ", "fluxes", " ", "using", " ", "the", " ", "exact", " ",
         "steady", " ", "state", " ", "solution"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"JsPL", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
             "v61PlsC", "+", "v71PlsC", "+", "v56PlsC", "+", "v81PlsC"}], 
             ")"}], "/.", " ", "ratesPLS"}], "/.", " ", "tsolSS"}], "/.", " ",
           "kinParamsLiPh"}], "/.", " ", "enzymeConcsPLS"}], "/.", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"(", "var_", ")"}], "[", "t", "]"}], ":>", "var"}]}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"JsLP", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", "vLpxK", ")"}], "/.", " ", "ratesLPS"}], "/.", " ", 
           "tsolSS"}], "/.", " ", "kinParamsLiPh"}], "/.", " ", 
         "enzymeConcsLPS"}], "/.", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"(", "var_", ")"}], "[", "t", "]"}], ":>", "var"}]}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"JsPL", "=", 
       RowBox[{
        RowBox[{"JsPL", "/.", " ", "optParams"}], "/.", 
        RowBox[{"{", 
         RowBox[{"beta", "->", "PlsBbeta"}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"JsLP", "=", 
       RowBox[{
        RowBox[{"JsLP", "/.", " ", "optParams"}], "/.", 
        RowBox[{"{", 
         RowBox[{"beta", "->", "PlsBbeta"}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Return", " ", "only", " ", "the", " ", "numeric", " ", "fluxes", " ", 
        "needed", " ", "for", " ", "the", " ", "objective", " ", 
        "calculation"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"JsPL", ",", "JsLP"}], "}"}]}]}], "]"}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"GlobalOptimizationObjective", "[", 
     RowBox[{"bet_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "simFluxes", ",", "simPL", ",", "objectiveValue", ",", "rawAvgFlux"}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"simFluxes", "=", 
        RowBox[{"ParallelTable", "[", 
         RowBox[{
          RowBox[{"EvaluateSteadyStateFluxes", "[", 
           RowBox[{
            RowBox[{"malCoAInputs", "[", 
             RowBox[{"[", "c", "]"}], "]"}], ",", "bet"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"c", ",", "1", ",", 
            RowBox[{"Length", "[", "malCoAInputs", "]"}]}], "}"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"simPL", "=", 
        RowBox[{"simFluxes", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rawAvgFlux", "=", 
        RowBox[{
         RowBox[{"Total", "[", "simPL", "]"}], "/", 
         RowBox[{"Length", "[", "simPL", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"objectiveValue", "=", 
        RowBox[{"-", "rawAvgFlux"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"optList", "=", 
        RowBox[{"Append", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"ListQ", "[", "optList", "]"}], ",", "optList", ",", 
            RowBox[{"{", "}"}]}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<ApproxGeneration\>\"", "->", 
             RowBox[{"Floor", "[", 
              RowBox[{
               RowBox[{"Length", "[", "optList", "]"}], "/", "population"}], 
              "]"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"\"\<IndividualID\>\"", "->", 
             RowBox[{
              RowBox[{"Length", "[", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"ListQ", "[", "optList", "]"}], ",", "optList", ",", 
                 
                 RowBox[{"{", "}"}]}], "]"}], "]"}], "+", "1"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Beta\>\"", "->", "bet"}], ",", "\[IndentingNewLine]", 
            RowBox[{"\"\<AvgFluxOutput\>\"", "->", "rawAvgFlux"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<FluxOutputDistribution\>\"", "->", "simPL"}]}], 
           "|>"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Update", " ", "the", " ", "absolute", " ", "best", " ", "score", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"most", " ", "negative", " ", "objective"}], "=", 
           RowBox[{"highest", " ", "flux"}]}], ")"}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"objectiveValue", "<", "bestScore"}], ",", 
         RowBox[{"bestScore", "=", "objectiveValue"}]}], "]"}], ";", 
       "\[IndentingNewLine]", "objectiveValue"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DistributeDefinitions", "[", 
    RowBox[{
    "malCoAInputs", ",", "DilutionPL", ",", "EvaluateSteadyStateFluxes", ",", 
