       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"GlobalOptimizationObjective", "[", "bet", "]"}], ",", 
          RowBox[{"1.0", "<=", "bet", "<=", "1400.0"}]}], "}"}], ",", 
        RowBox[{"{", "bet", "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Method", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<DifferentialEvolution\>\"", ",", 
