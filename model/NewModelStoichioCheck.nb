Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Force", " ", "vectorV", " ", "to", " ", "be", " ", "ONLY", " ", "the", " ",
     "symbols", " ", "used", " ", "in", " ", "the", " ", "expressions"}], 
   "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"vectorV", "=", 
     RowBox[{"Intersection", "[", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"DeleteDuplicates", "[", 
          RowBox[{"Cases", "[", 
           RowBox[{"vectorR", ",", "_Symbol", ",", "All"}], "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"StringStartsQ", "[", 
           RowBox[{
            RowBox[{"ToString", "[", "#", "]"}], ",", "\"\<v\>\""}], "]"}], 
          "&"}]}], "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{"This", " ", "ensures", " ", "we", " ", 
         RowBox[{"don", "'"}], "t", " ", "include", " ", "parameters", " ", 
         "that", " ", 
         RowBox[{"aren", "'"}], "t", " ", "in", " ", "the", " ", 
         "equations"}], "*)"}], 
       RowBox[{"DeleteDuplicates", "[", 
        RowBox[{"Cases", "[", 
         RowBox[{"vectorR", ",", "_Symbol", ",", "All"}], "]"}], "]"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Ensure", " ", "vectorMetabs", " ", "matches", " ", "the", " ", "number", 
     " ", "of", " ", "equations"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "vectorMetabs", "]"}], "!=", 
       RowBox[{"Length", "[", "vectorR", "]"}]}], ",", 
      RowBox[{
      "Print", "[", "\"\<Warning: Mismatch between number of variables and \
equations!\>\"", "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"MCA", "[", 
    RowBox[{"vectorR", ",", "vectorMetabs", ",", "vectorV", ",", "vectorV"}], 
    "]"}]}]}]], "Input",
