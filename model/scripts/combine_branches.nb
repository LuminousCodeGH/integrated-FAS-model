Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"reactions", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "==", 
       RowBox[{"Total", "[", 
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "&"}], "/@", 
     "\[IndentingNewLine]", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"flux", "=", 
            RowBox[{"vectorVaug", "[", 
             RowBox[{"[", "j", "]"}], "]"}]}], ",", "extQ"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"extQ", "=", 
           RowBox[{"StringMatchQ", "[", 
            RowBox[{
             RowBox[{"SymbolName", "[", "flux", "]"}], ",", 
             RowBox[{"\"\<vin*\>\"", "|", "\"\<vout*\>\""}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"flux", ",", "\[IndentingNewLine]", 
            RowBox[{"DeleteCases", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Table", "[", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"matrixSaug", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}], "!=", "0"}], ",", 
                  "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"matrixSaug", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}], "*", 
                   "\[IndentingNewLine]", 
                   RowBox[{"If", "[", 
                    RowBox[{"extQ", ",", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"vectorMetabs", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "-", 
                    RowBox[{"ToExpression", "[", 
                    RowBox[{"\"\<$\>\"", "<>", 
                    RowBox[{"SymbolName", "[", 
                    RowBox[{"vectorMetabs", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "]"}]}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"vectorMetabs", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ",", 
                  "\[IndentingNewLine]", "Nothing"}], "\[IndentingNewLine]", 
                 "]"}], ",", "\[IndentingNewLine]", 
                RowBox[{"{", 
                 RowBox[{"i", ",", 
                  RowBox[{"Length", "[", "vectorMetabs", "]"}]}], "}"}]}], 
               "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
              "Nothing"}], "\[IndentingNewLine]", "]"}]}], 
           "\[IndentingNewLine]", "}"}]}]}], "\[IndentingNewLine]", "]"}], ",",
        "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"j", ",", 
         RowBox[{"Length", "[", "vectorVaug", "]"}]}], "}"}]}], "]"}]}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"reactionRules", "=", 
   RowBox[{"reactions", "/.", 
    RowBox[{"Equal", "->", "Rule"}]}]}], ";"}], "\[IndentingNewLine]", 
