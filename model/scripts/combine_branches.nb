           RowBox[{"#", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "0", ",", "1"}], "]"}], "]"}]}], "]"}]}], 
        "&"}]}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
