Cell["Augment the S-matrix with the external metabolites", "Text",
 CellChangeTimes->{{3.986628798344668*^9, 
  3.986628806787982*^9}},ExpressionUUID->"e877c97b-c7b0-45d6-87d9-\
b2c1da6c4b45"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"AugmentMatrixS", "[", 
    RowBox[{"S_", ",", "metabs_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "vectorMetabsExt", ",", "directions", ",", "externalIndices", ",", 
       "exchangeCols", ",", "newReactionNames"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "1.", " ", "Extract", " ", "info", " ", "from", " ", "the", " ", 
       "provided", " ", "list"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"vectorMetabsExt", "=", 
       RowBox[{"concsInStoichAnalysis", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"The", " ", "symbols", " ", "y3"}], ",", " ", "y5", ",", " ", 
        
        RowBox[{"etc", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"directions", "=", 
       RowBox[{"concsInStoichAnalysis", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
      RowBox[{"(*", " ", 
       RowBox[{"\"\<in\>\"", " ", "or", " ", "\"\<out\>\""}], " ", "*)"}], 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "2.", " ", "Find", " ", "the", " ", "row", " ", "index", " ", "of", " ",
         "each", " ", "external", " ", "metabolite", " ", "in", " ", "the", " ",
         "species", " ", "list"}], "*)"}], 
      RowBox[{"externalIndices", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Position", "[", 
           RowBox[{"metabs", ",", 
            RowBox[{"vectorMetabsExt", "[", 
             RowBox[{"[", "k", "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"Length", "[", "vectorMetabsExt", "]"}]}], "}"}]}], "]"}],
         "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "3.", " ", "Create", " ", "the", " ", "exchange", " ", "columns", " ", 
        
        RowBox[{"(", 
         RowBox[{
          RowBox[{"1", " ", "for", " ", "in"}], ",", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "for", " ", "out"}]}], ")"}]}], "*)"}], 
      RowBox[{"exchangeCols", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"col", "=", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"0", ",", 
               RowBox[{"Length", "[", "metabs", "]"}]}], "]"}]}], "}"}], ",", 
           
           RowBox[{
            RowBox[{
             RowBox[{"col", "[", 
              RowBox[{"[", 
               RowBox[{"externalIndices", "[", 
                RowBox[{"[", "k", "]"}], "]"}], "]"}], "]"}], "=", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"directions", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], "==", "\"\<in\>\""}], ",", 
               "1", ",", 
               RowBox[{"-", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
            "col"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", 
           RowBox[{"Length", "[", "vectorMetabsExt", "]"}]}], "}"}]}], 
        "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"4.", " ", "Augment", " ", "the", " ", "S"}], "-", 
        RowBox[{"Matrix", " ", "horizontally"}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"matrixSaug", "=", 
       RowBox[{"Join", "[", 
        RowBox[{"S", ",", 
         RowBox[{"Transpose", "[", "exchangeCols", "]"}], ",", "2"}], "]"}]}],
       ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
