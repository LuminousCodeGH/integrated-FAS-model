 RowBox[{
  RowBox[{
   RowBox[{"ODEsPLS", "=", 
    RowBox[{"ODEsInRatesPLS", "/.", "RatesPLS"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MergeODEs", "[", 
   RowBox[{"main_List", ",", "branch_List", ",", "keyword_String"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "addEqs", ",", "normalEqs", ",", "stripKeyword", ",", "branchMap", ",", 
      "updatedMain", ",", "newVars"}], "}"}], ",", 
    RowBox[{"(*", " ", 
     RowBox[{"Split", " ", "branch", " ", "equations"}], " ", "*)"}], 
    RowBox[{
     RowBox[{"addEqs", "=", 
      RowBox[{"Select", "[", 
       RowBox[{"branch", ",", 
        RowBox[{
         RowBox[{"StringContainsQ", "[", 
          RowBox[{
           RowBox[{"ToString", "[", 
            RowBox[{"First", "[", "#", "]"}], "]"}], ",", "keyword"}], "]"}], 
         "&"}]}], "]"}]}], ";", 
     RowBox[{"normalEqs", "=", 
      RowBox[{"Complement", "[", 
       RowBox[{"branch", ",", "addEqs"}], "]"}]}], ";", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Remove", " ", "keyword", " ", "from", " ", "derivative", " ", 
       "symbol"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"stripKeyword", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"#", "/.", " ", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Derivative", "[", "1", "]"}], "[", "sym_", "]"}], "[", 
           "t", "]"}], ":>", 
          RowBox[{
           RowBox[{
            RowBox[{"Derivative", "[", "1", "]"}], "[", 
            RowBox[{"ToExpression", "[", 
             RowBox[{"StringReplace", "[", 
              RowBox[{
               RowBox[{"SymbolName", "[", "sym", "]"}], ",", 
               RowBox[{"keyword", "->", "\"\<\>\""}]}], "]"}], "]"}], "]"}], "[",
            "t", "]"}]}]}], ")"}], "&"}]}], ";", 
     RowBox[{"addEqs", "=", 
      RowBox[{"stripKeyword", "/@", "addEqs"}]}], ";", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"Create", " ", "lookup", " ", "of", " ", "variable"}], " ", "->",
        " ", "RHS"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"branchMap", "=", 
      RowBox[{"Association", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"First", "[", "#", "]"}], "/.", " ", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Derivative", "[", "1", "]"}], "[", "v_", "]"}], "[", 
              "t", "]"}], ":>", "v"}]}], ")"}], "->", 
          RowBox[{"Last", "[", "#", "]"}]}], "&"}], "/@", "addEqs"}], "]"}]}],
      ";", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Add", " ", "ADD", " ", "terms", " ", "to", " ", "existing", " ", 
       "equations"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"updatedMain", "=", 
      RowBox[{"main", "/.", " ", 
       RowBox[{
        RowBox[{"eq", ":", 
         RowBox[{"(", 
          RowBox[{"lhs_", "==", "rhs_"}], ")"}]}], ":>", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "var", "}"}], ",", 
          RowBox[{
           RowBox[{"var", "=", 
            RowBox[{"lhs", "/.", " ", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"Derivative", "[", "1", "]"}], "[", "v_", "]"}], "[", 
               "t", "]"}], ":>", "v"}]}]}], ";", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"KeyExistsQ", "[", 
              RowBox[{"branchMap", ",", "var"}], "]"}], ",", 
             RowBox[{"lhs", "==", 
              RowBox[{"rhs", "+", 
               RowBox[{"branchMap", "[", "var", "]"}]}]}], ",", "eq"}], 
            "]"}]}]}], "]"}]}]}]}], ";", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Determine", " ", "which", " ", "normal", " ", "equations", " ", "are", 
       " ", "new"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"newVars", "=", 
      RowBox[{"Select", "[", 
       RowBox[{"normalEqs", ",", 
        RowBox[{
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"var", "=", 
             RowBox[{
              RowBox[{"First", "[", "#", "]"}], "/.", " ", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"Derivative", "[", "1", "]"}], "[", "v_", "]"}], "[",
                 "t", "]"}], ":>", "v"}]}]}], "}"}], ",", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"updatedMain", ",", 
             RowBox[{
              RowBox[{
               RowBox[{"Derivative", "[", "1", "]"}], "[", "var", "]"}], "[", 
              "t", "]"}]}], "]"}]}], "]"}], "&"}]}], "]"}]}], ";", 
     RowBox[{"Join", "[", 
      RowBox[{"updatedMain", ",", "newVars"}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ODEs", "=", 
   RowBox[{"MergeODEs", "[", 
    RowBox[{"ODEsFAS", ",", "ODEsLPS", ",", "\"\<ADD\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
