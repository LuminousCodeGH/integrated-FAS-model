Cell[BoxData[
 TagBox[GridBox[{
    {"\<\"dy(1,:) = k1_1r.*y(83,:) - k1_1f.*e1.*y(1,:)\"\>"},
    {"\<\" dy(2,:) = k1_2r.*y(84,:) - k1_2f.*y(83,:).*y(2,:)\"\>"},
    {"\<\" dy(3,:) = k1_3r.*y(86,:) + k3_1r.*y(90,:) - k1_3f.*y(85,:).*y(3,:) \
- k3_1f.*e3.*y(3,:)  - k10_4f.*e10.*y(3,:) + k10_4r.*y(305,:) - \
k8_4f.*e8.*y(3,:) + k8_4r.*y(308,:)\"\>"}
   },
   GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
