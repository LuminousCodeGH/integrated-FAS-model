Notebook[{
Cell["\<\
Convert MATLAB ODEs to Mathematica ODEs and save the new equations to disk\
\>", "Text",
 CellChangeTimes->{{3.980925043836678*^9, 
  3.9809250615759163`*^9}},ExpressionUUID->"914de624-6acd-42cd-afa1-\
ffefdae232e2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"inputFileYear", "=", "\"\<2022\>\""}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Change", " ", "this", " ", "to", " ", "2022", " ", "or", " ", "2020"}], 
   " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.980925165130714*^9, 3.980925214534079*^9}, {
  3.9809254629186897`*^9, 3.980925468169846*^9}, {3.980925751469852*^9, 
  3.980925758403204*^9}, {3.980926744711421*^9, 3.9809267448957787`*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"79e21b6e-a324-4a47-9188-be3752a56416"],

Cell["Convert the equations to Mathematica", "Text",
 CellChangeTimes->{{3.980925194588019*^9, 
  3.9809252033764553`*^9}},ExpressionUUID->"907de615-22d7-4615-a4b5-\
a7fb9f1ab30d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"inputPath", "=", 
  RowBox[{"FileNameJoin", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"ParentDirectory", "[", 
      RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ",", "\"\<raw_input\>\"",
      ",", 
     RowBox[{"inputFileYear", "<>", "\"\<_fox_ODEs_MATLAB.csv\>\""}]}], "}"}],
    "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"outputPath", "=", 
  RowBox[{"FileNameJoin", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"ParentDirectory", "[", 
      RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ",", 
     " ", "\"\<data/FAS\>\"", ",", 
     RowBox[{"inputFileYear", "<>", "\"\<_fox_ODEs.csv\>\""}]}], "}"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MakeMathematicaODEs", "[", "matlabEqs_", "]"}], ":=", " ", 
  RowBox[{"(*", " ", 
   RowBox[{"FUNC", ":", " ", 
    RowBox[{"Parse", " ", "the", " ", "ODEs", " ", "from", " ", "an", " ", 
     RowBox[{"Excel", "/", "CSV"}], " ", "sheet"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "repl1", ",", "repl2", ",", "repl3", ",", "repl4", ",", "repl5", ",", 
      "repl6", ",", "repl7", ",", "repl8", ",", "repl9", ",", "repl10", ",", 
      " ", "ODElist", ",", " ", "ODEexprs", ",", " ", "ODEs"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ODElist", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "<=", 
        RowBox[{"Length", "[", "matlabEqs", "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"repl1", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{
           RowBox[{"matlabEqs", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
           RowBox[{"\"\<y(\>\"", "->", "\"\<y\>\""}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"repl2", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"repl1", ",", 
           RowBox[{"\"\<,:)\>\"", "->", "\"\<[t]\>\""}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"repl3", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"repl2", ",", 
           RowBox[{"\"\<dy\>\"", "->", "\"\<y\>\""}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"repl4", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"repl3", ",", 
           RowBox[{"\"\<[t] =\>\"", "->", "\"\<'[t]==\>\""}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"repl5", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"repl4", ",", 
           RowBox[{"\"\<[t]  =\>\"", "->", "\"\<'[t]==\>\""}]}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"repl6", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"repl5", ",", 
           RowBox[{"\"\<.*\>\"", "->", "\"\< \>\""}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"repl7", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"repl6", ",", 
           RowBox[{"\"\<_\>\"", "->", "\"\<\>\""}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"repl8", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"repl7", ",", 
           RowBox[{"\"\<e_\>\"", "->", "\"\<e~[t]\>\""}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"repl9", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"repl8", ",", 
           RowBox[{"\"\<(\>\"", "->", "\"\<\>\""}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"repl10", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"repl9", ",", 
           RowBox[{"\"\<)\>\"", "->", "\"\<\>\""}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ODElist", "=", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"ODElist", ",", "repl10"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"i", "++"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"ToExpression", " ", "is", " ", 
           RowBox[{"a", " ", "'"}], "pure", " ", 
           RowBox[{"function", "'"}], " ", "that", " ", "terminates", " ", 
           "at", " ", 
           RowBox[{"the", " ", "'"}]}], "&"}], "'"}], ".", " ", "As"}], " ", 
       "input", " ", 
       RowBox[{"(", 
        RowBox[{"'", 
         RowBox[{"#", "'"}]}], ")"}], " ", "it", " ", "takes", " ", "every", " ",
        "element", " ", "from", " ", "the", " ", "ODElist", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"'", "/@"}], "'"}], ")"}], " ", "and", " ", "passes", " ", 
       "it", " ", "to", " ", "the", " ", "pure", " ", "function"}], " ", 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{"ODEexprs", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"ToExpression", "[", "#", "]"}], "&"}], "/@", "ODElist"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"ODEs", "=", 
      RowBox[{"ODEexprs", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"e1", "->", 
          RowBox[{"e1", "[", "t", "]"}]}], ",", 
         RowBox[{"e2", "->", 
          RowBox[{"e2", "[", "t", "]"}]}], ",", 
         RowBox[{"e3", "->", 
          RowBox[{"e3", "[", "t", "]"}]}], ",", 
         RowBox[{"e4", "->", 
          RowBox[{"e4", "[", "t", "]"}]}], ",", 
         RowBox[{"e4", "->", 
          RowBox[{"e4", "[", "t", "]"}]}], ",", 
         RowBox[{"e5", "->", 
          RowBox[{"e5", "[", "t", "]"}]}], ",", 
         RowBox[{"e6", "->", 
          RowBox[{"e6", "[", "t", "]"}]}], ",", 
         RowBox[{"e7", "->", 
          RowBox[{"e7", "[", "t", "]"}]}], ",", 
         RowBox[{"e8", "->", 
          RowBox[{"e8", "[", "t", "]"}]}], ",", 
         RowBox[{"e9", "->", 
          RowBox[{"e9", "[", "t", "]"}]}], ",", 
         RowBox[{"e10", "->", 
          RowBox[{"e10", "[", "t", "]"}]}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "ODEs", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"importedODEs", "=", 
   RowBox[{"Import", "[", "inputPath", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"importedODEs", "[", 
   RowBox[{"[", 
    RowBox[{"1", ";;", "3"}], "]"}], "]"}], "//", "TableForm"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ODEs", "=", 
   RowBox[{"MakeMathematicaODEs", "[", "importedODEs", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ODEs", "[", 
   RowBox[{"[", 
    RowBox[{"1", ";;", "3"}], "]"}], "]"}], "//", "TableForm"}]}], "Input",
 CellChangeTimes->{{3.980925083711958*^9, 3.9809250846717787`*^9}, 
   3.98092512638533*^9, {3.980925745572303*^9, 3.980925746230318*^9}, {
   3.980925777218878*^9, 3.980925828960691*^9}, 3.9809258868256817`*^9, {
   3.9809259186674223`*^9, 3.980925992435719*^9}, {3.98092654381989*^9, 
   3.9809265677586737`*^9}, {3.980926691128372*^9, 3.980926700344365*^9}, {
   3.993011993403634*^9, 
   3.9930119939673147`*^9}},ExpressionUUID->"9a860597-f7e9-4632-8373-\
eec8dc26439f"],

