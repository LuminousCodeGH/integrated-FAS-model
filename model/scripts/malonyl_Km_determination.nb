Cell["Run titration experiments to determine the Km.", "Text",
 CellChangeTimes->{{3.983442888546377*^9, 
  3.983442897375702*^9}},ExpressionUUID->"d3ba0e40-136f-4240-adeb-\
67806238c210"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"e2T", "=", "0.05"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GetInitialVelocity", "[", 
   RowBox[{"y8init_", ",", "e2T_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"sol", ",", 
      RowBox[{"tMax", "=", "0.1"}], ",", 
      RowBox[{"y4tot", "=", "1000"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"sol", "=", 
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"eqs", "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"y8zero", "->", "y8init"}], ",", 
           RowBox[{"e2tot", "->", "e2T"}], ",", 
           RowBox[{"y4zero", "->", "y4tot"}]}], "}"}]}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"y8", "[", "t", "]"}], ",", 
          RowBox[{"y9", "[", "t", "]"}], ",", 
          RowBox[{"y10", "[", "t", "]"}], ",", 
          RowBox[{"y87", "[", "t", "]"}], ",", 
          RowBox[{"y88", "[", "t", "]"}], ",", 
          RowBox[{"y89", "[", "t", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", "tMax"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<[S]: \>\"", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y8", "[", "t", "]"}], "/.", "sol"}], "/.", 
        RowBox[{"t", "->", 
         RowBox[{"tMax", "/", "10"}]}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"y10", "[", "t", "]"}], "/.", "sol"}], "/.", 
      RowBox[{"t", "->", 
       RowBox[{"tMax", "/", "100"}]}]}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"testConcentrations", "=", 
   RowBox[{"{", 
    RowBox[{
    "1", ",", "2", ",", "5", ",", "10", ",", "20", ",", "50", ",", "100", ",",
      "200", ",", "500"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"c", ",", 
       RowBox[{
        RowBox[{"GetInitialVelocity", "[", 
         RowBox[{"c", ",", "e2T"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"c", ",", "testConcentrations"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", "data", "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"model", "=", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"data", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Vmax", "*", "S"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"Km", "+", "S"}], ")"}]}], ",", 
       RowBox[{
        RowBox[{"Km", ">", "0"}], " ", "&&", " ", 
        RowBox[{"Vmax", ">", "0"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"Vmax", ",", "Km"}], "}"}], ",", "S"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Calculated Km for Malonyl-CoA: \>\"", ",", 
   RowBox[{"Km", "/.", " ", 
    RowBox[{"model", "[", "\"\<BestFitParameters\>\"", "]"}]}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"plot", "=", 
  RowBox[{"Show", "[", 
   RowBox[{
    RowBox[{"ListPlot", "[", 
     RowBox[{"data", ",", 
      RowBox[{"PlotStyle", "->", "Red"}], ",", 
      RowBox[{"PlotLabel", "->", "\"\<FabD Virtual Titration\>\""}], ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<[Malonyl-CoA]\>\"", ",", "\"\<Velocity\>\""}], "}"}]}]}],
      "]"}], ",", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"model", "[", "S", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"S", ",", "0", ",", "500"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<[Malonyl-CoA] (\[Micro]M)\>\"", 
       ",", "\"\<Velocity (\[Micro]M/s)\>\""}], "}"}]}], ",", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0.5", ",", "500"}], "}"}], ",", "Automatic"}], "}"}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
