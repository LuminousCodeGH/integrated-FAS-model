Cell[BoxData[{
 RowBox[{
  RowBox[{"SingleSubMM", "[", 
   RowBox[{"kcat_", ",", "E_", ",", "S_", ",", "Km_"}], "]"}], ":=", 
  FractionBox[
   RowBox[{"kcat", " ", "E", " ", "S"}], 
   RowBox[{"Km", "+", "S"}]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SingleSubNonCompInhMM", "[", 
   RowBox[{"kcat_", ",", "E_", ",", "S_", ",", "Km_", ",", "P_", ",", "Ki_"}],
    "]"}], ":=", 
  FractionBox[
   RowBox[{"kcat", " ", "E", " ", "S"}], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"Km", "+", "S"}], ")"}], 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      FractionBox["P", "Ki"]}], ")"}]}]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"TwoSubMM", "[", 
    RowBox[{
    "kcat_", ",", "E_", ",", "S1_", ",", "S2_", ",", "Km1_", ",", "Km2_"}], 
    "]"}], ":=", 
   FractionBox[
    RowBox[{"kcat", " ", "E", " ", "S1", " ", "S2"}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Km1", " ", "+", " ", "S1"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"Km2", "+", "S2"}], ")"}]}]]}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"New", " ", "multi"}], "-", 
    RowBox[{"substrate", " ", "competitive", " ", "rate", " ", "function"}]}],
    " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MultiSubCompMM", "[", 
   RowBox[{
   "kcat_", ",", "etot_", ",", "S1List_", ",", "Km1List_", ",", "S2_", ",", 
    "Km2_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "denomS1", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"denomS1", "=", 
      RowBox[{"1", "+", 
       RowBox[{"Total", "[", 
        RowBox[{"S1List", "/", "Km1List"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     FractionBox[
      RowBox[{"etot", "*", "kcat", "*", 
       RowBox[{"(", 
        FractionBox["S1List", "Km1List"], ")"}], "*", 
       RowBox[{"(", 
        FractionBox["S2", "Km2"], ")"}]}], 
      RowBox[{"denomS1", "*", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         FractionBox["S2", "Km2"]}], ")"}]}]]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MultiSubCompInhMM", "[", 
   RowBox[{
   "kcat_", ",", "etot_", ",", "S1List_", ",", "Km1List_", ",", "S2_", ",", 
    "Km2_", ",", "P_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"denomS1", ",", "denomS2"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"denomS1", "=", 
      RowBox[{"1", "+", 
       RowBox[{"Total", "[", 
        RowBox[{"S1List", "/", "Km1List"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"denomS2", "=", 
      RowBox[{"1", "+", 
       RowBox[{"(", 
        RowBox[{"S2", "/", "Km2"}], ")"}], "+", 
       RowBox[{"(", 
        RowBox[{"P", "/", "beta"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     FractionBox[
      RowBox[{"etot", "*", "kcat", "*", 
       RowBox[{"(", 
        FractionBox["S1List", "Km1List"], ")"}], "*", 
       RowBox[{"(", 
        FractionBox["S2", "Km2"], ")"}]}], 
      RowBox[{"denomS1", "*", "denomS2"}]]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TwoSubNonCompInhMM", "[", 
