Cell["Save the FAS enzyme estimates to a .csv", "Text",
 CellChangeTimes->{{3.983521432239588*^9, 
  3.983521442073518*^9}},ExpressionUUID->"da37cd53-f670-47a5-8c5b-\
92fc8cc76126"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"enzAssociations", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<FabA\>\"", "->", "e9tot"}], ",", 
     RowBox[{"\"\<FabB\>\"", "->", "e10tot"}], ",", 
     RowBox[{"\"\<FabD\>\"", "->", "e2tot"}], ",", 
     RowBox[{"\"\<FabF\>\"", "->", "e8tot"}], ",", 
     RowBox[{"\"\<FabG\>\"", "->", "e4tot"}], ",", 
     RowBox[{"\"\<FabH\>\"", "->", "e3tot"}], ",", 
     RowBox[{"\"\<FabI\>\"", "->", "e6tot"}], ",", 
     RowBox[{"\"\<FabZ\>\"", "->", "e5tot"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"exportList", "=", 
   RowBox[{"Thread", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Normal", "[", 
       RowBox[{
        RowBox[{"enzymeConcentrations", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{";;", "8"}], ",", "\"\<Enzyme\>\""}], "]"}], "]"}], "/.", 
        "enzAssociations"}], "]"}], ",", 
      RowBox[{
       SuperscriptBox["10", "6"], 
       RowBox[{"Normal", "[", 
        RowBox[{
         RowBox[{"enzymeConcentrations", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "\"\<Concentration\>\""}], "]"}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{";;", "8"}], ",", "2"}], "]"}], "]"}], "]"}]}]}], "}"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"exportList", "=", 
    RowBox[{"Join", "[", 
     RowBox[{"exportList", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"e1tot", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"e7tot", ",", "0"}], "}"}]}], "}"}]}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "These", " ", "concentrations", " ", "are", " ", "for", " ", "ACC", " ", 
    "and", " ", "TesA", " ", "respectively"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{
   RowBox[{"FileNameJoin", "[", 
    RowBox[{
     RowBox[{"ParentDirectory", "[", 
      RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ",", "\"\<data/FAS\>\"",
      ",", "\"\<FAS_enzyme_concentrations.csv\>\""}], "]"}], ",", 
   "exportList", ",", "\"\<CSV\>\""}], "]"}]}], "Input",
 CellChangeTimes->{{3.983521694561925*^9, 3.983521731486527*^9}, {
  3.983521768594195*^9, 3.983521804153839*^9}, {3.983522218500173*^9, 
