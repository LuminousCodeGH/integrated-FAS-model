Cell["Plot the concentrations of the enzymes", "Text",
 CellChangeTimes->{{3.981801519679296*^9, 
  3.981801526594101*^9}},ExpressionUUID->"959462fc-512d-4aee-8180-\
af3c7b0d2967"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"values", "=", 
   RowBox[{
    RowBox[{"enzymeConcentrations", "[", 
     RowBox[{"All", ",", 
      RowBox[{
       RowBox[{"Around", "[", 
        RowBox[{
         RowBox[{"Mean", "[", "#Concentration", "]"}], ",", 
         RowBox[{
          RowBox[{"StandardDeviation", "[", "#Concentration", "]"}], "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"Length", "[", "#Concentration", "]"}], "]"}]}]}], "]"}], 
       "&"}]}], "]"}], "//", "Normal"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"labels", "=", 
   RowBox[{
    RowBox[{"enzymeConcentrations", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "\"\<Enzyme\>\""}], "]"}], "]"}], "//", 
    "Normal"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"BarChart", "[", 
  RowBox[{
   RowBox[{"values", " ", 
    SuperscriptBox["10", "6"]}], ",", 
   RowBox[{"ChartLabels", "->", "labels"}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Enzyme (-)\>\"", ",", "\"\<Concentration (\[Mu]M)\>\""}], 
     "}"}]}], ",", 
   RowBox[{"ChartStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{
      RowBox[{"EdgeForm", "[", "Black", "]"}], ",", " ", "LightBlue"}], 
     "]"}]}], ",", 
   RowBox[{"ImageSize", "->", "Large"}], ",", 
   RowBox[{"GridLines", "->", "Automatic"}], ",", 
   RowBox[{
   "PlotLabel", 
    "->", "\"\<Estimated Enzyme Concentrations, Accounted for SE in Cell \
Volume\>\""}], ",", 
   RowBox[{"AspectRatio", "->", "1"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.981801541383038*^9, 3.9818015563315067`*^9}, 
