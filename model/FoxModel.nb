Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"reactionRules", "=", 
   RowBox[{"reactions", "/.", 
    RowBox[{"Equal", "->", "Rule"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"overalls", "=", 
   RowBox[{
    RowBox[{"Simplify", "[", 
     RowBox[{"matrixK", " ", ".", " ", "vectorVaug"}], "]"}], "/.", 
    "reactionRules"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"formatReaction", "[", "expr_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "rules", ",", "substrates", ",", "products", ",", "formatSide"}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"If", " ", "the", " ", "entry", " ", "is", " ", "0"}], ",", 
        " ", 
        RowBox[{"skip", " ", "it"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"expr", "===", "0"}], ",", 
         RowBox[{"Return", "[", "\"\<0\>\"", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Extract", " ", "coefficients", " ", "and", " ", "variable", " ", 
         "names"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"rules", "=", 
        RowBox[{"CoefficientRules", "[", 
         RowBox[{"expr", ",", 
          RowBox[{"Variables", "[", "expr", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"vars", "=", 
        RowBox[{"Variables", "[", "expr", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Separate", " ", "into", " ", "Left", " ", "and", " ", "Right", " ", 
         "based", " ", "on", " ", "the", " ", "sign", " ", "of", " ", "the", " ",
          "coefficient"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"substrates", "=", 
        RowBox[{"Select", "[", 
         RowBox[{"rules", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Last", "[", "#", "]"}], "<", "0"}], "&"}]}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"products", "=", 
        RowBox[{"Select", "[", 
         RowBox[{"rules", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Last", "[", "#", "]"}], ">", "0"}], "&"}]}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Helper", " ", "to", " ", "turn", " ", "lists", " ", "into", 
         " ", "\"\<2 y1 + y2\>\"", " ", "strings"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"formatSide", "[", "list_", "]"}], ":=", 
        RowBox[{"StringRiffle", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Map", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Function", "[", 
             RowBox[{"rule", ",", "\[IndentingNewLine]", 
              RowBox[{"With", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"coeff", "=", 
                   RowBox[{"Abs", "[", 
                    RowBox[{"Last", "[", "rule", "]"}], "]"}]}], ",", 
                  "\[IndentingNewLine]", 
                  RowBox[{"name", "=", 
                   RowBox[{"vars", "[", 
                    RowBox[{"[", 
                    RowBox[{
                    RowBox[{"Position", "[", 
                    RowBox[{
                    RowBox[{"First", "[", "rule", "]"}], ",", "1"}], "]"}], "[", 
                    RowBox[{"[", 
                    RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}], "]"}]}]}], 
                 "}"}], ",", "\[IndentingNewLine]", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"coeff", "==", "1"}], ",", 
                  RowBox[{"ToString", "[", "name", "]"}], ",", 
                  RowBox[{
                   RowBox[{"ToString", "[", "coeff", "]"}], "<>", "\"\< \>\"",
                    "<>", 
                   RowBox[{"ToString", "[", "name", "]"}]}]}], "]"}]}], 
               "]"}]}], "]"}], ",", "\[IndentingNewLine]", "list"}], "]"}], 
          ",", "\"\< + \>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"Join", " ", "sides", " ", "with", " ", "the", " ", "arrow"}],
         " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"formatSide", "[", "substrates", "]"}], "<>", "\"\< => \>\"", 
        "<>", 
        RowBox[{"formatSide", "[", "products", "]"}]}]}]}], "]"}]}], ";"}], 
  "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Apply", " ", "to", " ", "your", " ", "vector"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"formattedReactions", "=", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"formatReaction", "/@", "overalls"}], ",", 
      RowBox[{
       RowBox[{"#", "!=", "\"\<0\>\""}], "&"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Display", " ", "as", " ", "column"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Column", "[", "formattedReactions", "]"}], "\[IndentingNewLine]", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"DoExports", "[", 
     RowBox[{"[", "4", "]"}], "]"}], "==", "True"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
       "FileNameJoin", 
        "[", "\"\<./raw_output/YEAR_fox_overall_reactions.xlsx\>\"", "]"}], "//", 
       RowBox[{"StringReplace", "[", 
        RowBox[{"\"\<YEAR\>\"", "->", "ModelYear"}], "]"}]}], ",", 
      "formattedReactions", ",", "\"\<XLSX\>\""}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Print", "[", "\"\<Exported Overall Reactions\>\"", "]"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<Skipping Overall Reactions Export[]...\>\"", "]"}]}], 
  "]"}]}], "Input",
