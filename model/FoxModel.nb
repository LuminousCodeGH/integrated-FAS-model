Cell[TextData[{
 StyleBox["Step 3: ",
  FontWeight->"Bold"],
 "Calculate the stoichiometric matrix (S), the NullSpace of S (K) and the \
NullSpace of S.T (L0)."
}], "Text",
 CellChangeTimes->{{3.973749120593443*^9, 3.973749139354567*^9}, {
   3.973750889581731*^9, 3.973750890572748*^9}, {3.973761615990857*^9, 
