Cell[TextData[{
 StyleBox["Step 4.2: ",
  FontWeight->"Bold"],
 "Get the conserved moieties by augmenting the S-matrix with the identity \
matrix and performing Gaussian elimination. This is the same as the L0 matrix!"
}], "Text",
 CellChangeTimes->{{3.974364322244643*^9, 3.9743643839138727`*^9}, {
   3.974366649896105*^9, 3.9743666658259907`*^9}, {3.9743669041673403`*^9, 
   3.974366904956676*^9}, 
   3.974970964860058*^9},ExpressionUUID->"389c598d-6af2-4860-b9b8-\
32bd3e38ec3f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Analysis", " ", "according", " ", 
    RowBox[{"to", ":", " ", "doi", ":", 
     RowBox[{
      RowBox[{"10.1006", "/", "jtbi"}], ".2002", ".2547"}]}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"GetMoietiesMatrix", "[", "matrix_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "n", ",", "m", ",", " ", "augMatrix", ",", "rr", ",", "rrAug", ",", 
        "rrMat"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"n", ",", "m"}], "}"}], " ", "=", 
        RowBox[{"Dimensions", "[", "matrix", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"augMatrix", "=", 
        RowBox[{"Join", "[", 
         RowBox[{"matrix", ",", " ", 
          RowBox[{"IdentityMatrix", "[", "n", "]"}], ",", " ", "2"}], "]"}]}],
        ";", " ", 
       RowBox[{"(*", " ", 
        RowBox[{"Create", " ", 
         RowBox[{"an", " ", "[", 
          RowBox[{"n", " ", "x", " ", 
           RowBox[{"(", 
            RowBox[{"m", " ", "+", " ", "n"}], ")"}]}], "]"}], " ", 
         "augmented", " ", "matrix", " ", "by", " ", "joining", " ", "S", " ",
          "and", " ", "I", " ", "along", " ", "the", " ", "columns", 
         " ", "\"\<2\>\""}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"rr", "=", 
        RowBox[{"Normal", "[", 
         RowBox[{"RowReduce", "[", "augMatrix", "]"}], "]"}]}], ";", " ", 
       RowBox[{"(*", " ", 
        RowBox[{"Row", " ", "reduce", " ", "the", " ", "matrix"}], " ", 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"rrAug", "=", 
        RowBox[{"Normal", "[", 
         RowBox[{"rr", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", 
            RowBox[{
             RowBox[{"m", "+", "1"}], ";;", 
             RowBox[{"m", "+", "n"}]}]}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rrMat", "=", 
        RowBox[{"Normal", "[", 
         RowBox[{"rr", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", 
            RowBox[{"1", ";;", "m"}]}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Return", "[", 
        RowBox[{"{", 
         RowBox[{"rrMat", ",", "rrAug"}], "}"}], "]"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.974364284189136*^9, 3.974364317127965*^9}, {
  3.974364393162936*^9, 3.9743644052875633`*^9}, {3.974364541826936*^9, 
