Cell[TextData[{
 StyleBox["Step 1: ",
  FontWeight->"Bold"],
 "Import the ODEs with the rates (generated by the \
\[OpenCurlyQuote]mass_action_in_rates.py\[CloseCurlyQuote] script) and the \
mappings from the rate to expression."
}], "Text",
 CellChangeTimes->{{3.973669333896306*^9, 3.973669363706933*^9}, {
   3.973670170302796*^9, 3.973670189153679*^9}, 
   3.9737669316987553`*^9},ExpressionUUID->"36def15a-b5af-40a6-af72-\
d9d915b7491b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ODEsPath", "=", 
   RowBox[{
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"NotebookDirectory", "[", "]"}], ",", 
