c329369aea18"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"augmentMatrixS", "[", 
   RowBox[{"S_", ",", "metabs_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"importExportEqs", ",", "externalIndices", ",", "exchangeCols"}],
      "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"importExportEqs", "=", 
      RowBox[{"Import", "[", 
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"NotebookDirectory", "[", "]"}], ",", 
          " ", "\"\<data/FAS/fox_import_export_equations.csv\>\""}], "}"}], 
        "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"vectorMetabsExt", "=", 
      RowBox[{"Symbol", "/@", 
       RowBox[{"importExportEqs", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "2"}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"externalIndices", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Position", "[", 
          RowBox[{"metabs", ",", "#"}], "]"}], "&"}], "/@", 
        "vectorMetabsExt"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"exchangeCols", "=", 
      RowBox[{"Table", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"col", "=", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"0", ",", 
               RowBox[{"Length", "[", "metabs", "]"}]}], "]"}]}], ",", 
            "dir"}], "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"dir", "=", 
            RowBox[{"importExportEqs", "[", 
             RowBox[{"[", 
              RowBox[{"k", ",", "3"}], "]"}], "]"}]}], ";", " ", 
           RowBox[{"(*", " ", 
            RowBox[{"\"\<in\>\"", " ", "or", " ", "\"\<out\>\""}], " ", 
            "*)"}], "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"col", "[", 
             RowBox[{"[", 
              RowBox[{"externalIndices", "[", 
               RowBox[{"[", "k", "]"}], "]"}], "]"}], "]"}], "=", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"dir", "==", "\"\<in\>\""}], ",", "1", ",", 
              RowBox[{"-", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
           "col"}]}], "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"k", ",", 
          RowBox[{"Length", "[", "externalIndices", "]"}]}], "}"}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"matrixSaug", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"S", ",", 
        RowBox[{"Transpose", "[", "exchangeCols", "]"}], ",", "2"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"vectorVaug", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"vectorV", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"Symbol", "[", 
           RowBox[{"StringReplace", "[", 
            RowBox[{"#", ",", 
             RowBox[{"{", 
              RowBox[{"\"\<_\>\"", "->", "\"\<\>\""}], "}"}]}], "]"}], "]"}], 
          "&"}], "/@", 
         RowBox[{"importExportEqs", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "1"}], "]"}], "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<External metabolites: \>\"", ",", "vectorMetabsExt", ",", 
       " ", 
       RowBox[{"\"\<(\>\"", " ", "<>", " ", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", "vectorMetabsExt", "]"}], "]"}], " ", 
        "<>", "\"\<)\>\""}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Augmented S-matrix: \>\"", " ", "<>", " ", 
       RowBox[{"ToString", "[", 
        RowBox[{"Dimensions", "[", "matrixSaug", "]"}], "]"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"matrixS", "=", 
   RowBox[{"Normal", "[", 
    RowBox[{
     RowBox[{"CoefficientArrays", "[", 
      RowBox[{"vectorR", ",", " ", "vectorV"}], "]"}], "[", 
     RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Assert", "[", 
   RowBox[{
    RowBox[{"MatrixQ", "[", "matrixS", "]"}], "==", "True"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"matrixKint", "=", 
   RowBox[{"NullSpace", "[", "matrixS", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"matrixL0int", "=", 
   RowBox[{"NullSpace", "[", 
    RowBox[{"matrixS", "//", "Transpose"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"augmentMatrixS", "[", 
   RowBox[{"matrixS", ",", "vectorMetabs"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"matrixK", "=", 
   RowBox[{"NullSpace", "[", "matrixSaug", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"matrixL0", "=", 
   RowBox[{"NullSpace", "[", 
    RowBox[{"matrixSaug", "//", "Transpose"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Dimensions S: \>\"", " ", "<>", " ", 
    RowBox[{"ToString", "[", 
     RowBox[{"Dimensions", "[", "matrixS", "]"}], "]"}], " ", "<>", " ", 
    "\[IndentingNewLine]", "\"\<, Rank: \>\"", " ", "<>", " ", 
    RowBox[{"ToString", "[", 
     RowBox[{"MatrixRank", "[", "matrixS", "]"}], "]"}], " ", "<>", " ", 
    "\[IndentingNewLine]", "\"\<, Dimensions Null(S): \>\"", " ", "<>", " ", 
    RowBox[{"ToString", "[", 
     RowBox[{"Dimensions", "[", "matrixKint", "]"}], "]"}], " ", "<>", " ", 
    "\[IndentingNewLine]", "\"\<, Dimensions Null(S.T): \>\"", " ", "<>", " ", 
    RowBox[{"ToString", "[", 
     RowBox[{"Dimensions", "[", "matrixL0int", "]"}], "]"}], "<>", 
    "\[IndentingNewLine]", "\"\<, Dimensions Null(Saug): \>\"", " ", "<>", 
    " ", 
    RowBox[{"ToString", "[", 
     RowBox[{"Dimensions", "[", "matrixK", "]"}], "]"}], " ", "<>", 
    "\[IndentingNewLine]", "\"\<, Dimensions Null(Saug.T): \>\"", " ", "<>", 
    " ", 
    RowBox[{"ToString", "[", 
     RowBox[{"Dimensions", "[", "matrixL0", "]"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"DoExports", "[", 
     RowBox[{"[", "1", "]"}], "]"}], "==", "True"}], ",", 
   RowBox[{"(*", " ", 
    RowBox[{"TODO", ":", " ", 
     RowBox[{
      RowBox[{"Accomodate", " ", "S"}], "-", 
      RowBox[{"augmented", " ", 
       RowBox[{"change", "!"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vectorMetabsStr", "=", 
     RowBox[{"ToString", "/@", "vectorMetabs"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"vectorMetabsIntStr", "=", 
     RowBox[{"ToString", "/@", "vectorMetabsInt"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"vectorVaugStr", "=", 
     RowBox[{"ToString", "/@", "vectorVaug"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"vectorVStr", "=", 
     RowBox[{"ToString", "/@", "vectorV"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"\"\<./scripts/efm_script/input/YEAR_S_matrix.mat\>\"", "//", 
       RowBox[{"StringReplace", "[", 
        RowBox[{"\"\<YEAR\>\"", "->", "ModelYear"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<S\>\"", "->", "matrixS"}], ",", 
        RowBox[{"\"\<metabs\>\"", "->", "vectorMetabsStr"}], ",", 
        RowBox[{"\"\<v\>\"", "->", "vectorVStr"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"\"\<./scripts/efm_script/input/YEAR_Saug_matrix.mat\>\"", "//", 
       RowBox[{"StringReplace", "[", 
        RowBox[{"\"\<YEAR\>\"", "->", "ModelYear"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<S\>\"", "->", "matrixSaug"}], ",", 
        RowBox[{"\"\<metabs\>\"", "->", "vectorMetabsStr"}], ",", 
        RowBox[{"\"\<v\>\"", "->", "vectorVaugStr"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
    "Print", "[", "\"\<Exporting S.mat and Saug.mat to \
'./scripts/efm_script/input/'...\>\"", "]"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", "\"\<Skipping Export[]...\>\"", "]"}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.973749160906844*^9, 3.9737491741828423`*^9}, {
   3.9737494429741592`*^9, 3.973749463197721*^9}, {3.973749495183853*^9, 
   3.973749498347069*^9}, {3.973749557992539*^9, 3.973749558485611*^9}, {
