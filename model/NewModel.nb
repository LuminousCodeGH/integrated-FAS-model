Cell[CellGroupData[{

Cell["Simulate Steady State Concentrations", "Chapter",
 CellChangeTimes->{{3.9816240347787943`*^9, 3.9816240443563633`*^9}, {
  3.9930106943078938`*^9, 
  3.9930107035349607`*^9}},ExpressionUUID->"ed9cd441-85b7-42cd-8144-\
b15a9b2aa063"],

Cell["As a function of a fixed Mal-CoA concentration", "Text",
 CellChangeTimes->{{3.982137763345047*^9, 
  3.982137777173534*^9}},ExpressionUUID->"dc9dd75f-09aa-4ba5-ba43-\
a3c3c3a9cc71"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Target", " ", "concentrations", " ", "and", " ", "intermediates", " ", 
    "to", " ", "track"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ConcMalCoA", "=", 
     RowBox[{"{", 
      RowBox[{
      "25", ",", "50", ",", "75", ",", "100", ",", "150", ",", "200", ",", 
       "300", ",", "400", ",", "500", ",", "750"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"concsToPlot", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"yP3", "[", "t", "]"}], ",", 
       RowBox[{"yP2", "[", "t", "]"}], ",", 
       RowBox[{"y23", "[", "t", "]"}], ",", 
       RowBox[{"y24", "[", "t", "]"}], ",", 
       RowBox[{"y25", "[", "t", "]"}], ",", 
       RowBox[{"y45", "[", "t", "]"}], ",", 
       RowBox[{"yL7", "[", "t", "]"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"allRateRules", "=", 
     RowBox[{"Join", "[", 
      RowBox[{"ratesFAS", ",", "ratesLPS", ",", "ratesPLS"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"allRateRules", "=", 
    RowBox[{"DeleteDuplicatesBy", "[", 
     RowBox[{"allRateRules", ",", "First"}], "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FattyAcidsAsFunction", "[", 
     RowBox[{"malCoA_", ",", "concs_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "ODEsFinalLocal", ",", "initsFinalLocal", ",", "tsol", ",", "tsolSS", ",",
         "steadyStateEqs", ",", "varsSS", ",", "rhsReplaceMap", ",", 
        "initialGuessValues", ",", "guessPairs", ",", "timeSS", ",", 
        "evaluatedConcs", ",", "rateSymbols", ",", "evaluatedRates", ",", 
        "fixedConcsRules"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"timeSS", "=", "99000"}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Setup", " ", "initial", " ", "conditions"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"initsFinalLocal", "=", 
         RowBox[{"inits", "/.", " ", "kinParamsIO"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"initsFinalLocal", "=", 
         RowBox[{"initsFinalLocal", "/.", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"y4", "[", "0", "]"}], "==", "_"}], ":>", 
            RowBox[{
             RowBox[{"y4", "[", "0", "]"}], "==", "ACPconc"}]}], ")"}]}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"fixedConcsRules", "=", 
         RowBox[{"Cases", "[", 
          RowBox[{"kinParamsIO", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"key_", "->", "val_"}], ")"}], "/;", 
             RowBox[{"StringEndsQ", "[", 
              RowBox[{
               RowBox[{"SymbolName", "[", "key", "]"}], ",", "\"\<ref\>\""}], 
              "]"}]}], ":>", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"ToExpression", "[", 
               RowBox[{"StringDrop", "[", 
                RowBox[{
                 RowBox[{"SymbolName", "[", "key", "]"}], ",", 
                 RowBox[{"-", "3"}]}], "]"}], "]"}], "->", "val"}], ")"}]}]}],
           "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Setup", " ", 
          RowBox[{"ODEs", ":", " ", 
           RowBox[{
            RowBox[{
            "Substitute", " ", "the", " ", "parameter", " ", "for", " ", 
             "Malonyl"}], "-", 
            RowBox[{"CoA", " ", "concentration", " ", "here"}]}]}]}], "*)"}], 
        
        RowBox[{"ODEsFinalLocal", "=", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"ODEs", "/.", " ", "kinParamsFAS"}], "/.", " ", 
               "kinParamsLiPh"}], "/.", " ", "kinParamsIO"}], "/.", " ", 
             "enzymeConcsFAS"}], "/.", " ", "enzymeConcsLPS"}], "/.", " ", 
           "enzymeConcsPLS"}], "/.", " ", 
          RowBox[{"(", 
           RowBox[{"y2ref", "->", "0"}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ODEsFinalLocal", "=", 
         RowBox[{"ODEsFinalLocal", "/.", " ", 
          RowBox[{"(", 
           RowBox[{"y8ref", "->", "malCoA"}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{
          "Run", " ", "NDSolve", " ", "to", " ", "get", " ", "close", " ", 
           "to", " ", "steady", " ", "state"}], "-", 
          RowBox[{"provides", " ", "initial", " ", "guess"}]}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"tsol", "=", 
         RowBox[{"NDSolve", "[", 
          RowBox[{
           RowBox[{"Join", "[", 
            RowBox[{"ODEsFinalLocal", ",", "initsFinalLocal"}], "]"}], ",", 
           "vars", ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "0", ",", "timeSS"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Convert", " ", "ODEs", " ", "to", " ", "algebraic", " ", 
          "equations"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"steadyStateEqs", "=", 
         RowBox[{"ODEsFinalLocal", "/.", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"Equal", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"Derivative", "[", "1", "]"}], "[", "_", "]"}], "[", 
                "t", "]"}], ",", "rhs_"}], "]"}], ":>", "rhs"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"(", "var_", ")"}], "[", "t", "]"}], ":>", "var"}]}], 
           "}"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"varsSS", "=", 
         RowBox[{"vars", "/.", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"(", "var_", ")"}], "[", "t", "]"}], ":>", "var"}]}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"rhsReplaceMap", "=", 
         RowBox[{"Thread", "[", 
          RowBox[{"vars", "->", "varsSS"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"steadyStateEqs", "=", 
         RowBox[{"steadyStateEqs", "/.", " ", "rhsReplaceMap"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Get", " ", "initial", " ", "guess", " ", "from", " ", "NDSolve", " ",
           "solution"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"initialGuessValues", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"vars", "/.", " ", "tsol"}], "/.", " ", 
            RowBox[{"t", "->", "timeSS"}]}], ")"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"guessPairs", "=", 
         RowBox[{"Thread", "[", 
          RowBox[{"{", 
           RowBox[{"varsSS", ",", "initialGuessValues"}], "}"}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Solve", " ", "for", " ", "exact", " ", "steady", " ", "state"}], 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"tsolSS", "=", 
         RowBox[{"FindRoot", "[", 
          RowBox[{
           RowBox[{"Thread", "[", 
            RowBox[{"steadyStateEqs", "==", "0"}], "]"}], ",", "guessPairs", ",", 
           RowBox[{"MaxIterations", "->", "50000"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Calculate", " ", "fluxes", " ", "using", " ", "steady", " ", 
          "state", " ", "solution"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"rateSymbols", "=", 
         RowBox[{"Keys", "[", "allRateRules", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"evaluatedRates", "=", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{"rateSymbols", "/.", " ", "allRateRules"}], "/.", 
                   " ", "kinParamsFAS"}], "/.", " ", "kinParamsLiPh"}], "/.", 
                 " ", "kinParamsIO"}], "/.", " ", "enzymeConcsFAS"}], "/.", 
               " ", "enzymeConcsLPS"}], "/.", " ", "enzymeConcsPLS"}], "/.", 
             RowBox[{
              RowBox[{
               RowBox[{"(", "var_", ")"}], "[", "t", "]"}], ":>", "var"}]}], "/.",
