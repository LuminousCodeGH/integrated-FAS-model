Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"This", " ", "replaces", " ", 
     RowBox[{
      RowBox[{"yXXX", "'"}], "[", "t", "]"}]}], "==", 
    RowBox[{
    "functions", " ", "with", " ", "just", " ", "the", " ", "functions"}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"steadyStateEqs", "=", 
     RowBox[{"ODEsFinal", "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"Equal", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Derivative", "[", "1", "]"}], "[", "_", "]"}], "[", "t",
             "]"}], ",", "rhs_"}], "]"}], ":>", "rhs"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"(", "var_", ")"}], "[", "t", "]"}], ":>", "var"}]}], 
       "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"varsSS", "=", 
     RowBox[{"vars", "/.", 
      RowBox[{
       RowBox[{
        RowBox[{"(", "var_", ")"}], "[", "t", "]"}], ":>", "var"}]}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"timeSS", "=", "99000"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhsReplaceMap", "=", 
     RowBox[{"Thread", "[", 
      RowBox[{"vars", "->", "varsSS"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"steadyStateEqs", "=", 
     RowBox[{"steadyStateEqs", "/.", "rhsReplaceMap"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"initialGuessValues", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"vars", "/.", " ", "tsol"}], "/.", " ", 
        RowBox[{"t", "->", "timeSS"}]}], ")"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"guessPairs", "=", 
     RowBox[{"Thread", "[", 
      RowBox[{"{", 
       RowBox[{"varsSS", ",", "initialGuessValues"}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tsolSS", "=", 
     RowBox[{"FindRoot", "[", 
      RowBox[{
       RowBox[{"Thread", "[", 
        RowBox[{"steadyStateEqs", "==", "0"}], "]"}], ",", "guessPairs", ",", 
       
       RowBox[{"MaxIterations", "->", "10000"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"JPL", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"v61PlsC", "+", "v71PlsC", "+", "v56PlsC", "+", "v81PlsC"}],
           ")"}], "/.", "ratesPLS"}], "/.", "tsolSS"}], "/.", 
       "kinParamsLiPh"}], "/.", "enzymeConcsPLS"}], "/.", 
     RowBox[{
      RowBox[{
       RowBox[{"(", "var_", ")"}], "[", "t", "]"}], ":>", "var"}]}]}], "\[IndentingNewLine]", 
   RowBox[{"JLP", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", "vLpxK", ")"}], "/.", "ratesLPS"}], "/.", "tsolSS"}], "/.",
        "kinParamsLiPh"}], "/.", "enzymeConcsLPS"}], "/.", 
     RowBox[{
      RowBox[{
       RowBox[{"(", "var_", ")"}], "[", "t", "]"}], ":>", "var"}]}]}], "\[IndentingNewLine]", 
