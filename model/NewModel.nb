    RowBox[{
     RowBox[{"Release", " ", "of", " ", "FabD", " ", "and", " ", "Mal"}], "-",
      "ACP"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"JACPs", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Total", "[", "RatesAcACPs", "]"}], "/.", " ", "tsolSS"}], "/.",
       " ", "kinParamsFAS"}], "/.", " ", "enzymeConcsFAS"}]}], "\[IndentingNewLine]", 
