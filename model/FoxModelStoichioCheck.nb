               "2", "\[RightDoubleBracket]"}], "-", "1"}]}], "}"}]}], "]"}]}],
        ",", 
       RowBox[{"Frame", "\[Rule]", "True"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"xLabel", ",", "yLabel"}], "}"}]}], ",", 
       RowBox[{"BaseStyle", "\[Rule]", "14"}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Thickness", "[", "0.05`", "]"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{
             RowBox[{"Length", "[", "Dat", "]"}], "-", "1"}]}], "}"}]}], 
         "]"}]}], ",", 
       RowBox[{"Epilog", "\[Rule]", 
        RowBox[{"Thread", "[", 
