 RowBox[{
  RowBox[{
   RowBox[{"NormalizeKernel", "[", "Km_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", 
     RowBox[{
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ColInd", "=", "1"}], ";", 
         RowBox[{"GoodRow", "=", 
          RowBox[{"{", "}"}]}]}], ",", 
        RowBox[{"ColInd", "\[LessEqual]", 
         RowBox[{
          RowBox[{"Dimensions", "[", "Km", "]"}], "\[LeftDoubleBracket]", "2",
           "\[RightDoubleBracket]"}]}], ",", 
        RowBox[{
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"RowInd", "=", "1"}], ",", 
           RowBox[{"RowInd", "\[LessEqual]", 
            RowBox[{
             RowBox[{"Dimensions", "[", "Km", "]"}], "\[LeftDoubleBracket]", 
             "1", "\[RightDoubleBracket]"}]}], ",", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Km", "\[LeftDoubleBracket]", 
                RowBox[{"RowInd", ",", "ColInd"}], "\[RightDoubleBracket]"}], 
               "\[NotEqual]", "0"}], ",", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Count", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"TakeRows", "[", 
                    RowBox[{"Km", ",", 
                    RowBox[{"{", 
                    RowBox[{"RowInd", ",", "RowInd"}], "}"}]}], "]"}], "\[LeftDoubleBracket]",
                     "1", "\[RightDoubleBracket]"}], ",", "0"}], "]"}], "\[Equal]", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Dimensions", "[", "Km", "]"}], "\[LeftDoubleBracket]",
                    "2", "\[RightDoubleBracket]"}], "-", "1"}]}], ",", 
                RowBox[{
                 RowBox[{"AppendTo", "[", 
                  RowBox[{"GoodRow", ",", 
                   RowBox[{"{", 
                    RowBox[{"ColInd", ",", "RowInd"}], "}"}]}], "]"}], ";", 
                 RowBox[{"Break", "[", "]"}]}]}], "]"}]}], "]"}], ";", 
            RowBox[{"RowInd", "=", 
             RowBox[{"RowInd", "+", "1"}]}]}]}], "]"}], ";", 
         RowBox[{"ColInd", "=", 
          RowBox[{"ColInd", "+", "1"}]}], ";"}]}], "]"}], ";", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "\[LessEqual]", 
         RowBox[{
          RowBox[{"Dimensions", "[", "Km", "]"}], "\[LeftDoubleBracket]", "2",
           "\[RightDoubleBracket]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"A", "[", "i", "]"}], "=", 
          FractionBox[
           RowBox[{"TakeColumns", "[", 
            RowBox[{"Km", ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "i"}], "}"}]}], "]"}], 
           RowBox[{"Km", "\[LeftDoubleBracket]", 
            RowBox[{
             RowBox[{
              RowBox[{
              "GoodRow", "\[LeftDoubleBracket]", "i", 
               "\[RightDoubleBracket]"}], "\[LeftDoubleBracket]", "2", 
              "\[RightDoubleBracket]"}], ",", "i"}], 
            "\[RightDoubleBracket]"}]]}], ";", 
         RowBox[{"i", "=", 
          RowBox[{"i", "+", "1"}]}]}]}], "]"}], ";", 
      RowBox[{"NormMat", "=", 
       RowBox[{"Transpose", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Flatten", "[", 
           RowBox[{"A", "[", "i", "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{
             RowBox[{"Dimensions", "[", "Km", "]"}], "\[LeftDoubleBracket]", 
             "2", "\[RightDoubleBracket]"}]}], "}"}]}], "]"}], "]"}]}]}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"FrequencyResponseAnalysis", "[", 
   RowBox[{
   "ODES_", ",", "Init_", ",", "tSS_", ",", "RateEqs_", ",", "Parm_", ",", 
    "PertParm_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", 
    RowBox[{
     RowBox[{"vExpl", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
         "RateEqs", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], "\[LeftDoubleBracket]",
          "2", "\[RightDoubleBracket]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"Length", "[", "RateEqs", "]"}]}], "}"}]}], "]"}]}], ";", 
     RowBox[{"pdvpdp", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{
         SubscriptBox["\[PartialD]", "PertParm"], "vExpl"}], "}"}], "]"}]}], ";", 
     RowBox[{"ElasticityMatrix", "=", 
      RowBox[{"Outer", "[", 
       RowBox[{"D", ",", "vExpl", ",", "Vars"}], "]"}]}], ";", 
     RowBox[{"JacobianMatrix", "=", 
      RowBox[{"NR", ".", "ElasticityMatrix", ".", "LmOrd"}]}], ";", 
     RowBox[{"sI", "=", 
      RowBox[{"s", " ", 
       RowBox[{"IdentityMatrix", "[", 
        RowBox[{
         RowBox[{"Dimensions", "[", "JacobianMatrix", "]"}], "\[LeftDoubleBracket]",
          "1", "\[RightDoubleBracket]"}], "]"}]}]}], ";", 
     RowBox[{"FreqResponse", "=", 
      RowBox[{"LmOrd", ".", 
       RowBox[{"Inverse", "[", 
        RowBox[{"sI", "-", "JacobianMatrix"}], "]"}], ".", "NR", ".", 
       "pdvpdp"}]}], ";", 
     RowBox[{"SS", "=", 
      RowBox[{"SSSol", "[", 
       RowBox[{"tSS", ",", "ODES", ",", 
        RowBox[{"RateEqs", "/.", "\[InvisibleSpace]", "Parm"}], ",", "Vars", ",",
         "Init"}], "]"}]}], ";", 
     RowBox[{"FreqResponseNum", "=", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"FreqResponse", "/.", "\[InvisibleSpace]", 
          RowBox[{"s", "\[Rule]", 
           RowBox[{"\[Omega]", " ", "\[ImaginaryI]"}]}]}], "/.", 
         "\[InvisibleSpace]", "Parm"}], "/.", "\[InvisibleSpace]", "SS"}], 
       "]"}]}], ";", 
     RowBox[{
     "Print", "[", "\"\<Note that ordering of rows in Frequency response is \
according to ordering of metabolites (=OrdVars)\>\"", "]"}], ";"}]}], 
   "]"}]}], "\n", 
 RowBox[{
  RowBox[{"BodePlots", "[", 
   RowBox[{"Equation_", ",", "LowerBoundFreq_", ",", "UpperBoundFreq_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", 
    RowBox[{
     RowBox[{"HdBs", "=", 
      RowBox[{"20", " ", 
       RowBox[{"Log", "[", 
        RowBox[{"10", ",", 
         RowBox[{"Abs", "[", "Equation", "]"}]}], "]"}]}]}], ";", 
     RowBox[{"Hangles", "=", 
      FractionBox[
       RowBox[{"360", " ", 
        RowBox[{"Arg", "[", "Equation", "]"}]}], 
       RowBox[{"2", " ", "\[Pi]"}]]}], ";", 
     RowBox[{"MagPlot", "=", 
      RowBox[{"LogLinearPlot", "[", 
       RowBox[{"HdBs", ",", 
        RowBox[{"{", 
         RowBox[{"\[Omega]", ",", "LowerBoundFreq", ",", "UpperBoundFreq"}], 
         "}"}], ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"LowerBoundFreq", ",", "UpperBoundFreq"}], "}"}], ",", 
           "All"}], "}"}]}], ",", 
        RowBox[{"GridLines", "\[Rule]", "Automatic"}], ",", 
        RowBox[{"PlotPoints", "\[Rule]", "5000"}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"Thickness", "[", "0.01`", "]"}]}], ",", 
        RowBox[{"Frame", "\[Rule]", "True"}], ",", 
        RowBox[{"FrameLabel", "\[Rule]", 
         RowBox[{"{", 
          
          RowBox[{"\"\<Frequency [rads/time unit]\>\"", 
           ",", "\"\<Magnitude [dB]\>\""}], "}"}]}], ",", 
        RowBox[{"PlotLabel", "\[Rule]", "\"\<Magnitude Plot\>\""}], ",", 
        RowBox[{"DisplayFunction", "\[Rule]", "Identity"}]}], "]"}]}], ";", 
     RowBox[{"PhasePlot", "=", 
      RowBox[{"LogLinearPlot", "[", 
       RowBox[{"Hangles", ",", 
        RowBox[{"{", 
         RowBox[{"\[Omega]", ",", "LowerBoundFreq", ",", "UpperBoundFreq"}], 
         "}"}], ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"LowerBoundFreq", ",", "UpperBoundFreq"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "182"}], ",", "182"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"GridLines", "\[Rule]", "Automatic"}], ",", 
        RowBox[{"PlotPoints", "\[Rule]", "5000"}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"Thickness", "[", "0.01`", "]"}]}], ",", 
        RowBox[{"Frame", "\[Rule]", "True"}], ",", 
        RowBox[{"FrameLabel", "\[Rule]", 
         RowBox[{"{", 
          
          RowBox[{"\"\<Frequency [rads/time unit]\>\"", 
           ",", "\"\<phase [deg]\>\""}], "}"}]}], ",", 
        RowBox[{"PlotLabel", "\[Rule]", "\"\<Phase Plot\>\""}], ",", 
        RowBox[{"DisplayFunction", "\[Rule]", "Identity"}]}], "]"}]}], ";", 
     RowBox[{"Show", "[", 
      RowBox[{"GraphicsRow", "[", 
       RowBox[{"{", 
        RowBox[{"MagPlot", ",", "PhasePlot"}], "}"}], "]"}], "]"}]}]}], 
   "]"}]}]}], "Input",
