        RowBox[{"{", 
         RowBox[{"0", ",", "1", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0", ",", "1"}], "}"}]}], "}"}]}], ";", 
     RowBox[{"MultipleListPlot", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"AppendRows", "[", 
          RowBox[{"xAx", ",", 
           RowBox[{"TakeColumns", "[", 
            RowBox[{"Dat", ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "i"}], "}"}]}], "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "2", ",", 
           RowBox[{
            RowBox[{"Dimensions", "[", "Dat", "]"}], "\[LeftDoubleBracket]", 
            "2", "\[RightDoubleBracket]"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"Joined", "\[Rule]", "True"}], ",", 
       RowBox[{"SymbolShape", "\[Rule]", "None"}], ",", 
