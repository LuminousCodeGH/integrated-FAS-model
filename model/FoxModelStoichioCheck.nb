        RowBox[{"j", "=", "0"}]}], ",", 
       RowBox[{"j", "<", 
        RowBox[{"Length", "[", "Reactions", "]"}]}], ",", 
       RowBox[{
        RowBox[{"j", "++"}], ";", 
        RowBox[{"r", "=", 
         RowBox[{
          RowBox[{
          "Reactions", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}],
           "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], ";", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "0"}], ",", 
          RowBox[{"i", "<", 
           RowBox[{"Length", "[", "r", "]"}]}], ",", 
          RowBox[{
           RowBox[{"i", "++"}], ";", 
           RowBox[{"M", "=", 
            RowBox[{
            "r", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]}], ";", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"StringMatchQ", "[", 
              RowBox[{
               RowBox[{"ToString", "[", "M", "]"}], ",", "\"\<-*\>\""}], 
              "]"}], ",", 
             RowBox[{"M", "=", 
              RowBox[{"-", "M"}]}], ",", 
             RowBox[{"M", "=", "M"}]}], "]"}], ";", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"StringMatchQ", "[", 
              RowBox[{
               RowBox[{"ToString", "[", "M", "]"}], ",", "\"\<*$*\>\""}], 
              "]"}], ",", 
             RowBox[{"Break", "[", "]"}], ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"TrueQ", "[", 
                RowBox[{
                 RowBox[{"Head", "[", "M", "]"}], "\[Equal]", "Times"}], 
                "]"}], ",", 
               RowBox[{"AppendTo", "[", 
                RowBox[{"Vars", ",", 
                 RowBox[{
                 "M", "\[LeftDoubleBracket]", "2", 
                  "\[RightDoubleBracket]"}]}], "]"}], ",", 
               RowBox[{"AppendTo", "[", 
                RowBox[{"Vars", ",", "M"}], "]"}]}], "]"}]}], "]"}]}]}], 
         "]"}]}]}], "]"}], ";", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "0"}], ",", 
       RowBox[{"i", "<", 
